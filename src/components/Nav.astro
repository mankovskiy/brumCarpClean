---
import { WA_URL, PHONE_RAW, PHONE_DISPLAY, NAV_LINKS } from '../data/site';
---

<header id="site-header" role="banner">
  <div class="nav-inner container">

    <a href="#home" class="nav-logo" aria-label="FreshLine Cleaning — return to top">
      <div class="nav-logo-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round" focusable="false">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </div>
      <span class="nav-logo-text">FreshLine<span class="nav-logo-dot" aria-hidden="true">.</span></span>
    </a>

    <nav class="nav-links" aria-label="Primary navigation">
      {NAV_LINKS.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <div class="nav-actions">
      <a href={`tel:${PHONE_RAW}`} class="nav-phone" aria-label={`Call us: ${PHONE_DISPLAY}`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 18z"/>
        </svg>
        <span>{PHONE_DISPLAY}</span>
      </a>

      <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="btn-wa"
         aria-label="Get a WhatsApp quote (opens WhatsApp)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.117 1.529 5.845L0 24l6.335-1.658A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.006-1.371l-.36-.213-3.76.985.998-3.658-.235-.375A9.818 9.818 0 1 1 12 21.818z"/>
        </svg>
        WhatsApp Quote
      </a>

      <button
        id="nav-toggle"
        class="nav-burger"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" class="hidden" aria-hidden="true" focusable="false">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6"  y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu" aria-label="Mobile navigation" aria-hidden="true" hidden>
    <nav>
      {NAV_LINKS.map(link => (
        <a href={link.href} class="mobile-link">{link.label}</a>
      ))}
      <div class="mobile-actions">
        <a href={`tel:${PHONE_RAW}`} class="mobile-call" aria-label={`Call us: ${PHONE_DISPLAY}`}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 18z"/>
          </svg>
          Call Now
        </a>
        <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="mobile-wa"
           aria-label="Get a WhatsApp quote (opens WhatsApp)">
          Get a Quote
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    transition: background 0.25s, box-shadow 0.25s;
  }
  header.scrolled {
    background: #fff;
    box-shadow: 0 1px 0 var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    gap: 1rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-shrink: 0;
    border-radius: 8px;
    padding: 0.25rem;
  }
  .nav-logo-icon {
    width: 34px; height: 34px;
    background: var(--blue);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .nav-logo-text {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: white;
    transition: color 0.25s;
    line-height: 1;
  }
  .nav-logo-dot { color: var(--green-xl); }
  header.scrolled .nav-logo-text { color: var(--navy); }

  .nav-links {
    display: none;
    align-items: center;
    gap: 0.125rem;
  }
  @media (min-width: 1024px) { .nav-links { display: flex; } }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    color: rgba(255,255,255,0.82);
    transition: color 0.2s, background 0.2s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .nav-link:hover { color: #fff; background: rgba(255,255,255,0.1); }
  header.scrolled .nav-link       { color: var(--navy-7); }
  header.scrolled .nav-link:hover { color: var(--blue); background: #eff6ff; }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-phone {
    display: none;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255,255,255,0.75);
    transition: color 0.2s;
    white-space: nowrap;
    min-height: 44px;
  }
  @media (min-width: 768px) { .nav-phone { display: flex; } }
  .nav-phone:hover { color: #fff; }
  header.scrolled .nav-phone       { color: var(--muted); }
  header.scrolled .nav-phone:hover { color: var(--navy); }

  .btn-wa {
    display: none;
    align-items: center;
    gap: 0.5rem;
    background: var(--green);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
    min-height: 44px;
  }
  @media (min-width: 640px) { .btn-wa { display: flex; } }
  .btn-wa:hover { background: var(--green-l); transform: translateY(-1px); }

  .nav-burger {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    cursor: pointer;
    color: white;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  @media (min-width: 1024px) { .nav-burger { display: none; } }
  .nav-burger:hover { background: rgba(255,255,255,0.2); }
  header.scrolled .nav-burger { background: #f3f4f6; border-color: var(--border); color: var(--navy); }
  .hidden { display: none !important; }

  .mobile-menu {
    background: #fff;
    border-top: 1px solid var(--border);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .mobile-menu[hidden] { display: none; }
  .mobile-menu nav {
    padding: 0.75rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .mobile-link {
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--navy-7);
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
    min-height: 44px;
    display: flex;
    align-items: center;
  }
  .mobile-link:hover { background: #eff6ff; color: var(--blue); }

  .mobile-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .mobile-call, .mobile-wa {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 700;
    text-align: center;
    min-height: 48px;
  }
  .mobile-call { background: #f3f4f6; color: var(--navy); border: 1.5px solid var(--border); }
  .mobile-call:hover { background: #e5e7eb; }
  .mobile-wa   { background: var(--green); color: #fff; }
  .mobile-wa:hover { background: var(--green-l); }
</style>

<script>
  const header    = document.getElementById('site-header')!;
  const toggle    = document.getElementById('nav-toggle')!;
  const menu      = document.getElementById('mobile-menu')!;
  const iconMenu  = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  function updateHeader() {
    header.classList.toggle('scrolled', window.scrollY > 30);
  }
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  function openMenu() {
    menu.hidden = false;
    menu.removeAttribute('aria-hidden');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close navigation menu');
    iconMenu.classList.add('hidden');
    iconClose.classList.remove('hidden');
  }
  function closeMenu() {
    menu.hidden = true;
    menu.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open navigation menu');
    iconMenu.classList.remove('hidden');
    iconClose.classList.add('hidden');
  }

  toggle.addEventListener('click', () => { menu.hidden ? openMenu() : closeMenu(); });
  menu.querySelectorAll('.mobile-link').forEach(l => l.addEventListener('click', closeMenu));
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && !menu.hidden) { closeMenu(); toggle.focus(); } });
</script>
