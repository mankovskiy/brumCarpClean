---
import { WA_URL, PHONE_RAW, PHONE_DISPLAY, HERO } from '../data/site';
---

<section id="home" aria-labelledby="hero-heading">

  <div class="hero-bg" role="presentation">
    <img
      src={HERO.image}
      alt=""
      width="1920"
      height="1080"
      fetchpriority="high"
      decoding="sync"
    />
    <div class="hero-overlay" aria-hidden="true"></div>
  </div>

  <div class="hero-content container">

    <div class="hero-pill" aria-hidden="true">
      <span class="pill-dot"></span>
      Birmingham &amp; West Midlands
    </div>

    <h1 id="hero-heading">{HERO.heading}</h1>

    <p class="hero-sub">{HERO.subheading}</p>

    <div class="hero-ctas">
      <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="cta-primary"
         aria-label="Get a WhatsApp quote — opens WhatsApp">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.117 1.529 5.845L0 24l6.335-1.658A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.006-1.371l-.36-.213-3.76.985.998-3.658-.235-.375A9.818 9.818 0 1 1 12 21.818z"/>
        </svg>
        Get a WhatsApp Quote
      </a>
      <a href={`tel:${PHONE_RAW}`} class="cta-secondary" aria-label={`Call us now: ${PHONE_DISPLAY}`}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 18z"/>
        </svg>
        Call Now
      </a>
    </div>

    <ul class="trust-bar" aria-label="Why choose FreshLine Cleaning">
      {HERO.trustPoints.map((point, i) => (
        <>
          <li class="trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--green-xl)"
                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true" focusable="false">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {point}
          </li>
          {i < HERO.trustPoints.length - 1 && (
            <li class="trust-divider" aria-hidden="true"></li>
          )}
        </>
      ))}
    </ul>

  </div>

  <a href="#services" class="scroll-cue" aria-hidden="true" tabindex="-1">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </a>

</section>

<style>
  section {
    position: relative;
    min-height: 100svh;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #0f172a;
  }

  .hero-bg { position: absolute; inset: 0; }
  .hero-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(155deg, rgba(9,18,42,0.90) 0%, rgba(12,25,58,0.80) 55%, rgba(9,22,50,0.65) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 8rem;
    padding-bottom: 6rem;
    max-width: 780px;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.8);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.4rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.75rem;
    user-select: none;
  }
  .pill-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green-xl);
    flex-shrink: 0;
    animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  h1 {
    font-size: clamp(2.2rem, 5.5vw, 3.75rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    color: rgba(255,255,255,0.72);
    line-height: 1.7;
    margin-bottom: 2.25rem;
    max-width: 560px;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 480px) { .hero-ctas { flex-direction: row; flex-wrap: wrap; } }

  .cta-primary, .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font-size: 1rem;
    font-weight: 700;
    border-radius: 10px;
    padding: 0.9rem 1.75rem;
    transition: transform 0.18s, box-shadow 0.18s, background 0.18s, border-color 0.18s;
    white-space: nowrap;
    min-height: 48px;
  }
  .cta-primary {
    background: var(--green);
    color: #fff;
    box-shadow: 0 4px 20px rgba(5,150,105,0.45);
  }
  .cta-primary:hover  { background: var(--green-l); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(5,150,105,0.5); }
  .cta-primary:active { transform: translateY(0); }
  .cta-secondary {
    background: rgba(255,255,255,0.08);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.25);
  }
  .cta-secondary:hover  { background: rgba(255,255,255,0.16); transform: translateY(-2px); border-color: rgba(255,255,255,0.4); }
  .cta-secondary:active { transform: translateY(0); }

  .trust-bar {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    padding: 1rem 1.25rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    max-width: 620px;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: rgba(255,255,255,0.82);
    white-space: nowrap;
  }
  .trust-divider { width: 1px; height: 14px; background: rgba(255,255,255,0.18); flex-shrink: 0; }
  @media (max-width: 479px) { .trust-divider { display: none; } }

  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.35);
    animation: bounce 2.5s ease-in-out infinite;
    z-index: 2;
    pointer-events: none;
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }
</style>
