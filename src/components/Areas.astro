---
import { AREAS } from '../data/site';
---

<section id="areas" aria-labelledby="areas-heading">
  <div class="container">
    <div class="layout">

      <div class="content">
        <span class="label">Coverage</span>
        <h2 id="areas-heading">Areas We Cover</h2>
        <p class="lead">
          We provide carpet and upholstery cleaning across Birmingham and the wider West Midlands.
          Not sure if we reach you? Just drop us a message — we're always happy to check.
        </p>

        <ul class="area-tags" aria-label="Areas covered by FreshLine Cleaning">
          {AREAS.map(area => (
            <li class="area-tag">{area}</li>
          ))}
          <li class="area-more" aria-label="and surrounding areas">&amp; surrounding areas</li>
        </ul>
      </div>

      <div class="visual" aria-label="Map showing FreshLine Cleaning coverage across Birmingham and the West Midlands" role="img">
        <!--
          Simplified schematic of the West Midlands metro area.
          Shapes are approximate stylised regions — not geographic boundaries.
          Coordinates are on a 400×340 viewBox.
          Central Birmingham is at roughly (200, 165).
        -->
        <svg
          viewBox="0 0 400 340"
          xmlns="http://www.w3.org/2000/svg"
          class="map-svg"
          aria-hidden="true"
          focusable="false"
        >
          <!-- ── Background card ── -->
          <rect width="400" height="340" rx="16" fill="#f0f4fa"/>

          <!-- ── Subtle grid lines ── -->
          <g stroke="#dbe4f0" stroke-width="0.5" opacity="0.6">
            <line x1="0" y1="85"  x2="400" y2="85"/>
            <line x1="0" y1="170" x2="400" y2="170"/>
            <line x1="0" y1="255" x2="400" y2="255"/>
            <line x1="100" y1="0" x2="100" y2="340"/>
            <line x1="200" y1="0" x2="200" y2="340"/>
            <line x1="300" y1="0" x2="300" y2="340"/>
          </g>

          <!-- ── Outer service ring (approx 35–40 mile radius) ── -->
          <circle cx="200" cy="165" r="148" fill="#dbeafe" opacity="0.5"/>

          <!-- ── Mid service ring (approx 15–20 mile radius) ── -->
          <circle cx="200" cy="165" r="98" fill="#bfdbfe" opacity="0.5"/>

          <!-- ── Core Birmingham metro blob ── -->
          <ellipse cx="200" cy="165" rx="58" ry="54" fill="#1d4ed8" opacity="0.18"/>

          <!-- ── Birmingham city shape (simplified polygon) ── -->
          <polygon
            points="185,120 215,118 232,130 238,152 235,175 220,190 198,195 178,188 163,172 162,150 172,133"
            fill="#1d4ed8"
            opacity="0.85"
          />

          <!-- ── Surrounding areas as labelled dots ── -->

          <!-- Sutton Coldfield (north) -->
          <circle cx="208" cy="93" r="9" fill="#2563eb" opacity="0.7"/>
          <text x="222" y="97" font-size="10" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600">Sutton Coldfield</text>

          <!-- West Bromwich (northwest) -->
          <circle cx="142" cy="143" r="8" fill="#2563eb" opacity="0.7"/>
          <text x="62" y="141" font-size="10" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600" text-anchor="middle">West</text>
          <text x="62" y="153" font-size="10" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600" text-anchor="middle">Bromwich</text>
          <line x1="142" y1="143" x2="82" y2="148" stroke="#2563eb" stroke-width="0.8" stroke-dasharray="3,2" opacity="0.5"/>

          <!-- Solihull (east) -->
          <circle cx="261" cy="185" r="9" fill="#2563eb" opacity="0.7"/>
          <text x="274" y="189" font-size="10" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600">Solihull</text>

          <!-- Shirley (southeast) -->
          <circle cx="248" cy="220" r="7" fill="#3b82f6" opacity="0.65"/>
          <text x="259" y="224" font-size="9.5" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600">Shirley</text>

          <!-- Kings Norton (south) -->
          <circle cx="192" cy="236" r="7" fill="#3b82f6" opacity="0.65"/>
          <text x="152" y="249" font-size="9.5" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600">Kings Norton</text>
          <line x1="192" y1="236" x2="185" y2="247" stroke="#3b82f6" stroke-width="0.8" stroke-dasharray="3,2" opacity="0.5"/>

          <!-- Northfield (south-southwest) -->
          <circle cx="169" cy="228" r="7" fill="#3b82f6" opacity="0.65"/>

          <!-- Selly Oak (southwest) -->
          <circle cx="162" cy="206" r="7" fill="#3b82f6" opacity="0.65"/>
          <text x="90" y="209" font-size="9.5" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600" text-anchor="middle">Selly Oak</text>
          <line x1="162" y1="206" x2="115" y2="207" stroke="#3b82f6" stroke-width="0.8" stroke-dasharray="3,2" opacity="0.5"/>

          <!-- Harborne (west) -->
          <circle cx="152" cy="180" r="7" fill="#3b82f6" opacity="0.65"/>
          <text x="76" y="178" font-size="9.5" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600" text-anchor="middle">Harborne</text>
          <line x1="152" y1="180" x2="105" y2="177" stroke="#3b82f6" stroke-width="0.8" stroke-dasharray="3,2" opacity="0.5"/>

          <!-- Edgbaston -->
          <circle cx="175" cy="175" r="6" fill="#3b82f6" opacity="0.6"/>

          <!-- Moseley -->
          <circle cx="203" cy="210" r="6" fill="#3b82f6" opacity="0.6"/>

          <!-- Redditch (far south) -->
          <circle cx="195" cy="295" r="8" fill="#2563eb" opacity="0.65"/>
          <text x="207" y="299" font-size="10" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600">Redditch</text>

          <!-- Bromsgrove (south) -->
          <circle cx="175" cy="268" r="7" fill="#3b82f6" opacity="0.6"/>
          <text x="118" y="272" font-size="9.5" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600" text-anchor="middle">Bromsgrove</text>
          <line x1="175" y1="268" x2="145" y2="270" stroke="#3b82f6" stroke-width="0.8" stroke-dasharray="3,2" opacity="0.5"/>

          <!-- Hall Green / Acocks Green (east-southeast) -->
          <circle cx="233" cy="205" r="6" fill="#3b82f6" opacity="0.6"/>

          <!-- ── Birmingham centre label ── -->
          <text x="200" y="160" font-size="11.5" font-family="system-ui,sans-serif" fill="#fff" font-weight="800" text-anchor="middle" letter-spacing="-0.3">BIRMINGHAM</text>
          <text x="200" y="174" font-size="8.5" font-family="system-ui,sans-serif" fill="rgba(255,255,255,0.82)" font-weight="600" text-anchor="middle" letter-spacing="0.5">CITY CENTRE</text>

          <!-- ── Pin icon on Birmingham ── -->
          <g transform="translate(196,106)" opacity="0.95">
            <circle cx="4" cy="4" r="7" fill="#059669"/>
            <circle cx="4" cy="4" r="3" fill="#fff"/>
          </g>

          <!-- ── Legend ── -->
          <g transform="translate(14, 290)">
            <rect width="122" height="38" rx="8" fill="white" opacity="0.88"/>
            <circle cx="18" cy="12" r="5" fill="#1d4ed8" opacity="0.85"/>
            <text x="27" y="16" font-size="9" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600">Core coverage</text>
            <circle cx="18" cy="27" r="5" fill="#bfdbfe" stroke="#2563eb" stroke-width="1"/>
            <text x="27" y="31" font-size="9" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="600">Extended area</text>
          </g>

          <!-- ── Compass rose (subtle) ── -->
          <g transform="translate(361,18)" opacity="0.35">
            <text x="6" y="11" font-size="9" font-family="system-ui,sans-serif" fill="#1e3a6e" font-weight="700" text-anchor="middle">N</text>
            <line x1="6" y1="13" x2="6" y2="24" stroke="#1e3a6e" stroke-width="1.2"/>
            <polygon points="6,13 4,19 6,17 8,19" fill="#1e3a6e"/>
          </g>
        </svg>
      </div>

    </div>
  </div>
</section>

<style>
  section { padding: 5.5rem 0; background: var(--stone); }

  .layout { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) { .layout { grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; } }

  .content { display: flex; flex-direction: column; gap: 1.75rem; }
  .content h2 { font-size: clamp(1.75rem, 3.5vw, 2.6rem); color: var(--navy); margin-top: 0.4rem; }
  .lead { font-size: 1rem; color: var(--muted); line-height: 1.75; }

  .area-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; list-style: none; }
  .area-tag {
    display: inline-flex; align-items: center;
    background: #fff; border: 1.5px solid var(--border); color: var(--navy-7);
    font-size: 0.82rem; font-weight: 600; padding: 0.35rem 0.8rem; border-radius: 100px;
    transition: border-color 0.15s, color 0.15s;
  }
  .area-tag:hover { border-color: var(--blue-xl); color: var(--blue); }
  .area-more { display: inline-flex; align-items: center; font-size: 0.82rem; color: var(--muted); padding: 0.35rem 0; }

  .visual { display: flex; align-items: center; justify-content: center; }

  .map-svg {
    width: 100%;
    max-width: 460px;
    height: auto;
    border-radius: var(--radius);
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    display: block;
  }
</style>
