---
import { WA_URL, TG_URL, PHONE_RAW, PHONE_DISPLAY, EMAIL, FACEBOOK_URL } from '../data/site';
---

<section id="contact" aria-labelledby="contact-heading">

  <!-- Primary CTA band -->
  <div class="contact-hero">
    <div class="container">
      <div class="contact-hero-inner">

        <div class="contact-text">
          <span class="label light">Get in Touch</span>
          <h2 id="contact-heading">Ready for Fresh Carpets?</h2>
          <p>
            The fastest way to get a quote is to send us a few photos on WhatsApp.
            We usually respond within the hour — often within minutes.
          </p>
        </div>

        <div class="contact-ctas">
          <a
            href={WA_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="cta-wa"
            aria-label="Send photos on WhatsApp for a quote — opens WhatsApp"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"
                 aria-hidden="true" focusable="false">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.117 1.529 5.845L0 24l6.335-1.658A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.006-1.371l-.36-.213-3.76.985.998-3.658-.235-.375A9.818 9.818 0 1 1 12 21.818z"/>
            </svg>
            Send Photos on WhatsApp
          </a>

          <a
            href={`tel:${PHONE_RAW}`}
            class="cta-phone"
            aria-label={`Call us: ${PHONE_DISPLAY}`}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true" focusable="false">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 18z"/>
            </svg>
            {PHONE_DISPLAY}
          </a>
        </div>

      </div>
    </div>
  </div>

  <!-- Secondary contact methods -->
  <div class="contact-more">
    <div class="container">
      <p class="more-label" id="more-contact-label">More ways to reach us</p>

      <ul class="more-grid" role="list" aria-labelledby="more-contact-label">

        <li>
          <a href={`mailto:${EMAIL}`} class="more-card" aria-label={`Email us at ${EMAIL}`}>
            <div class="more-icon email-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" focusable="false">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <strong>Email</strong>
              <span>{EMAIL}</span>
            </div>
          </a>
        </li>

        <li>
          <a href={TG_URL} target="_blank" rel="noopener noreferrer" class="more-card"
             aria-label="Message us on Telegram (opens Telegram)">
            <div class="more-icon tg-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" focusable="false">
                <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12l-6.869 4.326-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.829.941z"/>
              </svg>
            </div>
            <div>
              <strong>Telegram</strong>
              <span>Message us on Telegram</span>
            </div>
          </a>
        </li>

        <li>
          <a href={FACEBOOK_URL} target="_blank" rel="noopener noreferrer" class="more-card"
             aria-label="Visit FreshLine Cleaning on Facebook (opens Facebook)">
            <div class="more-icon fb-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" focusable="false">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </div>
            <div>
              <strong>Facebook</strong>
              <span>FreshLine Cleaning</span>
            </div>
          </a>
        </li>

      </ul>
    </div>
  </div>

</section>

<style>
  section { background: var(--navy); }

  /* Label variant for dark bg */
  .label.light { color: var(--green-xl); }

  /* Hero band */
  .contact-hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .contact-hero-inner {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .contact-hero-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
    }
  }

  .contact-text { max-width: 480px; }
  .contact-text h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: #fff;
    margin: 0.5rem 0 1rem;
  }
  .contact-text p { color: rgba(255,255,255,0.6); font-size: 1rem; line-height: 1.7; }

  .contact-ctas {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .cta-wa, .cta-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font-size: 1rem;
    font-weight: 700;
    padding: 0.9rem 1.75rem;
    border-radius: 10px;
    white-space: nowrap;
    transition: transform 0.18s, box-shadow 0.18s, background 0.18s;
    min-height: 52px;
    /* Stretch to same width on mobile */
    width: 100%;
  }
  @media (min-width: 768px) { .cta-wa, .cta-phone { width: auto; min-width: 260px; } }

  .cta-wa {
    background: var(--green);
    color: #fff;
    box-shadow: 0 4px 20px rgba(5,150,105,0.4);
  }
  .cta-wa:hover {
    background: var(--green-l);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(5,150,105,0.45);
  }
  .cta-wa:active { transform: translateY(0); }

  .cta-phone {
    background: rgba(255,255,255,0.07);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.18);
  }
  .cta-phone:hover { background: rgba(255,255,255,0.13); transform: translateY(-2px); }
  .cta-phone:active { transform: translateY(0); }

  /* More options */
  .contact-more { padding: 2.5rem 0 3.5rem; }
  .more-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 1.25rem;
  }

  .more-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    list-style: none;
  }
  @media (min-width: 640px) { .more-grid { grid-template-columns: repeat(3, 1fr); } }

  .more-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    color: #fff;
    transition: background 0.18s, transform 0.18s;
    min-height: 64px;
  }
  .more-card:hover { background: rgba(255,255,255,0.09); transform: translateY(-2px); }
  .more-card:active { transform: translateY(0); }

  .more-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  /* All icon bg colours have >3:1 contrast ratio for their foreground icon */
  .email-icon { background: rgba(99,102,241,0.25);  color: #a5b4fc; }
  .tg-icon    { background: rgba(14,165,233,0.25);  color: #7dd3fc; }
  .fb-icon    { background: rgba(59,130,246,0.25);  color: #93c5fd; }

  .more-card strong { display: block; font-size: 0.9rem;  font-weight: 700; }
  .more-card span   { display: block; font-size: 0.78rem; color: rgba(255,255,255,0.5); margin-top: 0.15rem; }
</style>
