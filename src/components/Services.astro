---
import { WA_URL, SERVICES } from '../data/site';
---

<section id="services" aria-labelledby="services-heading">
  <div class="container">

    <div class="section-header">
      <span class="label">What We Clean</span>
      <h2 id="services-heading">Our Cleaning Services</h2>
      <p class="section-sub">
        Professional equipment, careful stain treatment and a service you can trust —
        at your home, at a time that suits you.
      </p>
    </div>

    <ul class="services-grid" role="list">
      {SERVICES.map(s => (
        <li>
          <article class="service-card">
            <div class="card-image">
              <img
                src={s.image}
                alt={s.imageAlt}
                width="700"
                height="440"
                loading={s.eager ? 'eager' : 'lazy'}
                decoding={s.eager ? 'sync' : 'async'}
              />
              {s.tag && <span class="card-tag" aria-label={`Category: ${s.tag}`}>{s.tag}</span>}
            </div>
            <div class="card-body">
              <h3>{s.title}</h3>
              <p>{s.description}</p>
              <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="card-link"
                 aria-label={`Get a WhatsApp quote for ${s.title}`}>
                Get a quote
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" focusable="false">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </div>
          </article>
        </li>
      ))}
    </ul>

    <div class="services-cta">
      <p>Not sure what you need? Send us a photo and we'll advise you.</p>
      <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="btn-primary"
         aria-label="Get a free quote via WhatsApp (opens WhatsApp)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.117 1.529 5.845L0 24l6.335-1.658A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.006-1.371l-.36-.213-3.76.985.998-3.658-.235-.375A9.818 9.818 0 1 1 12 21.818z"/>
        </svg>
        WhatsApp for a Free Quote
      </a>
    </div>

  </div>
</section>

<style>
  section { padding: 5.5rem 0 5rem; background: var(--stone); }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 580px;
    margin-left: auto;
    margin-right: auto;
  }
  .section-header h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); color: var(--navy); margin-bottom: 0.9rem; }
  .section-sub { color: var(--muted); font-size: 1rem; line-height: 1.7; }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    list-style: none;
  }
  @media (min-width: 640px)  { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .services-grid { grid-template-columns: repeat(3, 1fr); } }

  .service-card {
    background: #fff;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    height: 100%;
    transition: transform 0.22s, box-shadow 0.22s;
  }
  .service-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,0.1); }

  .card-image {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #f0f0f0;
  }
  .card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .service-card:hover .card-image img { transform: scale(1.04); }

  .card-tag {
    position: absolute;
    top: 0.75rem; left: 0.75rem;
    background: var(--navy);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    user-select: none;
  }

  .card-body {
    padding: 1.4rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .card-body h3 { font-size: 1.05rem; color: var(--navy); }
  .card-body p  { font-size: 0.875rem; color: var(--muted); line-height: 1.65; flex: 1; }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--blue);
    transition: gap 0.2s, color 0.2s;
    margin-top: 0.5rem;
    padding: 0.25rem 0;
  }
  .card-link:hover { gap: 0.65rem; color: var(--navy); }

  .services-cta {
    margin-top: 3rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .services-cta p { color: var(--muted); font-size: 0.95rem; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--blue);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.85rem 1.75rem;
    border-radius: 10px;
    transition: background 0.18s, transform 0.18s, box-shadow 0.18s;
    box-shadow: 0 4px 16px rgba(29,78,216,0.3);
    min-height: 48px;
  }
  .btn-primary:hover  { background: var(--navy); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(29,78,216,0.35); }
  .btn-primary:active { transform: translateY(0); }
</style>
