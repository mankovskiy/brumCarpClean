---
import { BEFORE_AFTER } from '../data/site';
---

<section id="before-after" aria-labelledby="ba-heading">
  <div class="container">

    <div class="section-header">
      <span class="label">Results</span>
      <h2 id="ba-heading">Before &amp; After</h2>
      <p class="section-sub">
        Real results from real jobs in and around Birmingham.
        Send us your photos and see what we can do for you.
      </p>
    </div>

    <ul class="ba-grid" role="list">
      {BEFORE_AFTER.map(pair => (
        <li>
          <figure class="ba-card">
            <div class="ba-images" role="img"
                 aria-label={`Before and after: ${pair.label} in ${pair.location}`}>
              <div class="ba-half">
                <img src={pair.before.src} alt={pair.before.alt} width="350" height="220"
                     loading="lazy" decoding="async" />
                <span class="ba-label ba-before" aria-hidden="true">Before</span>
              </div>

              <div class="ba-divider" aria-hidden="true">
                <div class="ba-line"></div>
                <div class="ba-circle">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white"
                       stroke-width="2.5" stroke-linecap="round" focusable="false">
                    <polyline points="15 18 9 12 15 6"/>
                  </svg>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white"
                       stroke-width="2.5" stroke-linecap="round" focusable="false">
                    <polyline points="9 18 15 12 9 6"/>
                  </svg>
                </div>
              </div>

              <div class="ba-half">
                <img src={pair.after.src} alt={pair.after.alt} width="350" height="220"
                     loading="lazy" decoding="async" />
                <span class="ba-label ba-after" aria-hidden="true">After</span>
              </div>
            </div>

            <figcaption class="ba-caption">
              <strong>{pair.label}</strong>
              <span>{pair.location}</span>
            </figcaption>
          </figure>
        </li>
      ))}
    </ul>

    <p class="ba-note">
      Images are representative examples. Send us your photos on WhatsApp for a personalised quote.
    </p>

  </div>
</section>

<style>
  section { padding: 5.5rem 0; background: #fff; }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }
  .section-header h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); color: var(--navy); margin-bottom: 0.9rem; }
  .section-sub { color: var(--muted); font-size: 1rem; line-height: 1.7; }

  .ba-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; list-style: none; }
  @media (min-width: 768px) { .ba-grid { grid-template-columns: repeat(3, 1fr); } }

  .ba-card {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #fff;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  }

  .ba-images { display: grid; grid-template-columns: 1fr 28px 1fr; align-items: stretch; }

  .ba-half { position: relative; overflow: hidden; }
  .ba-half img { width: 100%; height: 220px; object-fit: cover; display: block; }
  @media (min-width: 768px) and (max-width: 1023px) { .ba-half img { height: 180px; } }

  .ba-label {
    position: absolute;
    bottom: 0.6rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    line-height: 1;
    pointer-events: none;
  }
  .ba-before { left: 0.6rem;  background: rgba(220,38,38,0.88);  color: #fff; }
  .ba-after  { right: 0.6rem; background: rgba(5,150,105,0.88);  color: #fff; }

  .ba-divider { position: relative; display: flex; align-items: center; justify-content: center; background: #fff; z-index: 2; flex-shrink: 0; }
  .ba-line { position: absolute; inset: 0; width: 2px; left: 50%; transform: translateX(-50%); background: var(--border); }
  .ba-circle {
    position: relative; z-index: 3;
    width: 26px; height: 26px;
    background: var(--navy);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .ba-caption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.1rem;
    border-top: 1px solid var(--border);
    background: #fafaf9;
  }
  .ba-caption strong { font-size: 0.875rem; font-weight: 700; color: var(--navy); }
  .ba-caption span   { font-size: 0.78rem;  color: var(--muted); }

  .ba-note { text-align: center; margin-top: 2rem; font-size: 0.8rem; color: #9ca3af; }
</style>
