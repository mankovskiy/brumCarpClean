---
import { WA_URL, FAQS } from '../data/site';

const waFaqURL = WA_URL.replace(
  encodeURIComponent('Hi, I would like a quote for carpet or upholstery cleaning. I can send photos.'),
  encodeURIComponent('Hi, I have a question about your cleaning service.')
);
---

<section id="faq" aria-labelledby="faq-heading">
  <div class="container">
    <div class="layout">

      <div class="faq-sidebar">
        <span class="label">FAQ</span>
        <h2 id="faq-heading">Common Questions</h2>
        <p class="lead">Can't find your answer here? Message us on WhatsApp — we reply quickly.</p>
        <a href={waFaqURL} target="_blank" rel="noopener noreferrer" class="btn-ask"
           aria-label="Ask a question on WhatsApp (opens WhatsApp)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.117 1.529 5.845L0 24l6.335-1.658A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.006-1.371l-.36-.213-3.76.985.998-3.658-.235-.375A9.818 9.818 0 1 1 12 21.818z"/>
          </svg>
          Ask us on WhatsApp
        </a>
      </div>

      <div class="faq-list" itemscope itemtype="https://schema.org/FAQPage">
        {FAQS.map((faq, i) => (
          <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h3>
              <button class="faq-q" type="button" aria-expanded="false"
                      aria-controls={`faq-a-${i}`} id={`faq-q-${i}`}>
                <span itemprop="name">{faq.q}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                     aria-hidden="true" focusable="false">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </button>
            </h3>
            <div id={`faq-a-${i}`} class="faq-a" role="region" aria-labelledby={`faq-q-${i}`}
                 hidden itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  section { padding: 5.5rem 0; background: #fff; }

  .layout { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) { .layout { grid-template-columns: 300px 1fr; gap: 5rem; align-items: start; } }

  .faq-sidebar { display: flex; flex-direction: column; gap: 1.25rem; }
  .faq-sidebar h2 { font-size: clamp(1.75rem, 3.5vw, 2.6rem); color: var(--navy); margin-top: 0.4rem; }
  .lead { font-size: 1rem; color: var(--muted); line-height: 1.75; }

  .btn-ask {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: #f0fdf4; color: var(--green); border: 1.5px solid #bbf7d0;
    font-size: 0.875rem; font-weight: 700; padding: 0.7rem 1.2rem;
    border-radius: 10px; align-self: flex-start; min-height: 44px;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-ask:hover { background: #dcfce7; border-color: #86efac; }

  .faq-list { display: flex; flex-direction: column; }
  .faq-item { border-bottom: 1px solid var(--border); }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-item h3 { margin: 0; font-weight: inherit; font-size: inherit; }

  .faq-q {
    width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1.2rem 0; background: none; border: none; cursor: pointer; text-align: left; min-height: 56px;
  }
  .faq-q span { font-size: 0.95rem; font-weight: 600; color: var(--navy); line-height: 1.4; }
  .faq-q:hover span { color: var(--blue); }

  .faq-chevron { color: var(--muted); flex-shrink: 0; transition: transform 0.2s ease, color 0.2s; }
  .faq-q[aria-expanded="true"] .faq-chevron { transform: rotate(180deg); color: var(--blue); }

  .faq-a { padding-bottom: 1.2rem; }
  .faq-a[hidden] { display: none; }
  .faq-a p { font-size: 0.9rem; color: var(--muted); line-height: 1.75; }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answer   = document.getElementById(btn.getAttribute('aria-controls')!) as HTMLElement;
      btn.setAttribute('aria-expanded', String(!expanded));
      answer.hidden = expanded;
    });
  });
</script>
