---
import { PROCESS_STEPS } from '../data/site';
---

<section aria-labelledby="process-heading">
  <div class="container">

    <div class="section-header">
      <span class="label light">How It Works</span>
      <h2 id="process-heading">Four Simple Steps</h2>
      <p class="section-sub">No long waits, no complicated forms. Getting clean carpets has never been easier.</p>
    </div>

    <ol class="steps" aria-label="How our service works: four steps">
      {PROCESS_STEPS.map((step, i) => (
        <li class="step">
          <div class="step-num" aria-hidden="true">{i + 1}</div>
          {i < PROCESS_STEPS.length - 1 && (
            <div class="step-connector" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                   stroke="rgba(255,255,255,0.2)" stroke-width="2" stroke-linecap="round" focusable="false">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </div>
          )}
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </li>
      ))}
    </ol>

  </div>
</section>

<style>
  section { padding: 5.5rem 0; background: var(--navy); }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .section-header h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); color: #fff; margin-bottom: 0.9rem; }
  .label.light { color: var(--green-xl); }
  .section-sub { color: rgba(255,255,255,0.55); font-size: 1rem; line-height: 1.7; }

  .steps { display: grid; grid-template-columns: 1fr; gap: 1.25rem; list-style: none; }
  @media (min-width: 768px) { .steps { grid-template-columns: repeat(4, 1fr); gap: 0; } }

  .step {
    position: relative;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .step { border-radius: 0; border-right: none; }
    .step:first-child { border-radius: var(--radius) 0 0 var(--radius); }
    .step:last-child  { border-radius: 0 var(--radius) var(--radius) 0; border-right: 1px solid rgba(255,255,255,0.08); }
  }

  .step-num {
    width: 44px; height: 44px;
    background: var(--blue);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.25rem; font-weight: 800; color: #fff;
    flex-shrink: 0;
  }

  .step-connector {
    display: none;
    position: absolute;
    right: -11px; top: 50%;
    transform: translateY(-50%);
    z-index: 2;
  }
  @media (min-width: 768px) { .step-connector { display: block; } }

  .step h3 { font-size: 1rem; font-weight: 700; color: #fff; letter-spacing: -0.01em; }
  .step p  { font-size: 0.875rem; color: rgba(255,255,255,0.55); line-height: 1.65; }
</style>
